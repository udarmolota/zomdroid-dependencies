+#define MAX_PROGRAMS 8192
+typedef struct {
+    GLuint program;
+    uint64_t last_dump_time_ms;
+} ShaderDumpInfo;
+
+ShaderDumpInfo shader_dump_cache[MAX_PROGRAMS];
+int shader_dump_count = 0;
+
+uint64_t time_ms() {
+    struct timespec ts;
+    clock_gettime(CLOCK_MONOTONIC, &ts);
+    return (uint64_t)(ts.tv_sec * 1000ULL + ts.tv_nsec / 1000000ULL);
+}
+
+int should_dump(GLuint program) {
+    uint64_t now = time_ms();
+    for (int i = 0; i < shader_dump_count; ++i) {
+        if (shader_dump_cache[i].program == program) {
+            if (now - shader_dump_cache[i].last_dump_time_ms >= 100) {
+                shader_dump_cache[i].last_dump_time_ms = now;
+                return 1;
+            }
+            return 0;
+        }
+    }
+
+    if (shader_dump_count < MAX_PROGRAMS) {
+        shader_dump_cache[shader_dump_count].program = program;
+        shader_dump_cache[shader_dump_count].last_dump_time_ms = now;
+        ++shader_dump_count;
+        return 1;
+    }
+
+    return 0;
+}
